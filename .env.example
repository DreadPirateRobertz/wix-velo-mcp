# wix-velo-mcp environment configuration
# Copy to .env and fill in values

# Required: paths to dev and prod Wix Velo repos
VELO_DEV_REPO=/path/to/dev/repo
VELO_PROD_REPO=/path/to/prod/repo

# Wix My Site 2 (staging) — metaSiteId
WIX_SITE_ID=49cd75b0-92f1-4978-93e2-f5b5da531142

# Wix headless OAuth client ID
WIX_CLIENT_ID=6e037f12-819f-4e81-a625-e7b0057df0ad

# Wix REST API key (from Wix Dashboard > API Keys)
WIX_API_KEY=

# Wix account ID (from Wix Dashboard > Account Settings)
WIX_ACCOUNT_ID=
